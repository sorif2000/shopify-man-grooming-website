<section class="page-hero" style="min-height:40vh">
  <div class="page-hero-bg" style="background-image:url('{{ 'hero-banner.png' | asset_url }}')"></div>
  <div class="container">
    <div class="page-hero-content">
      <p class="section-label"><i class="far fa-heart"></i> My Collection</p>
      <h1 class="section-title" style="font-size:clamp(2rem,5vw,3rem)">My Wishlist</h1>
      <p style="color:var(--text-secondary)" id="wishlistSummary">Products you've saved for later</p>
    </div>
  </div>
</section>

<section class="section" style="min-height:50vh">
  <div class="container">
    <div id="wishlistPageContent"></div>
  </div>
</section>

<script>
function renderWishlistPage() {
  const container = document.getElementById('wishlistPageContent');
  const summary = document.getElementById('wishlistSummary');
  if (wishlist.length === 0) {
    summary.textContent = 'Your wishlist is empty';
    container.innerHTML = `
      <div style="text-align:center;padding:60px 20px">
        <div style="font-size:4rem;color:var(--text-muted);margin-bottom:20px"><i class="far fa-heart"></i></div>
        <h3 style="font-family:var(--font-heading);margin-bottom:12px">No saved items yet</h3>
        <p style="color:var(--text-secondary);margin-bottom:24px">Start browsing and heart the products you love!</p>
        <a href="/#products" class="btn btn-primary" style="text-decoration:none">Browse Products <i class="fas fa-arrow-right"></i></a>
      </div>
    `;
    return;
  }
  summary.textContent = `${wishlist.length} saved item${wishlist.length > 1 ? 's' : ''}`;
  container.innerHTML = `
    <div class="wishlist-page-grid">
      \${wishlist.map(item => {
        const p = products.find(x => x.id === item.id) || item;
        const stars = p.rating ? '★'.repeat(Math.floor(p.rating)) : '★★★★★';
        return \`
          <div class="wishlist-page-card">
            <a href="/products/\${item.id}" class="wishlist-page-image">
              <img src="\${item.image}" alt="\${item.name}">
            </a>
            <div class="wishlist-page-info">
              <div class="product-category">\${item.category || 'grooming'}</div>
              <h3 class="product-name"><a href="/products/\${item.id}" style="color:inherit;text-decoration:none">\${item.name}</a></h3>
              <div class="product-rating"><span class="stars">\${stars}</span></div>
              <div class="product-price"><span class="price-current">$\${item.price.toFixed(2)}</span></div>
              <div style="display:flex;gap:8px;margin-top:16px">
                <button class="btn btn-primary" style="flex:1;justify-content:center;padding:10px 16px;font-size:0.75rem" onclick="addToCart(products.find(x=>x.id===\${item.id})||{id:\${item.id},name:'\${item.name.replace(/'/g,"\\\\'")}',price:\${item.price},image:'\${item.image}'})">
                  <i class="fas fa-shopping-bag"></i> Add to Cart
                </button>
                <button class="btn btn-outline" style="padding:10px 14px;font-size:0.75rem" onclick="removeFromWishlistPage(\${item.id})">
                  <i class="fas fa-trash-alt"></i>
                </button>
              </div>
            </div>
          </div>
        \`;
      }).join('')}
    </div>
  `;
}

function removeFromWishlistPage(id) {
  wishlist = wishlist.filter(w => w.id !== id);
  saveWishlist();
  updateWishlistUI();
  renderWishlistPage();
  showToast('Removed from wishlist');
}

window.addEventListener('load', renderWishlistPage);
</script>
