<!-- Newsletter -->
<section class="section" id="contact">
  <div class="container">
    <div class="newsletter reveal">
      <p class="section-label">Stay in the Loop</p>
      <h2 class="section-title">Join the GROOMVAULT Club</h2>
      <p class="section-desc">Get exclusive deals, grooming tips, and early access to new products.</p>
      <form class="newsletter-form" onsubmit="handleNewsletter(event)">
        <input type="email" placeholder="Your email address" required id="newsletterEmail">
        <button type="submit" class="btn btn-primary">Subscribe</button>
      </form>
    </div>
  </div>
</section>
